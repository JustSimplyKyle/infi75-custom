[general]
framerate = 60
# MATCH THIS TO 'ROW_WIDTH' IN RUST (17 is standard for 75% keyboards)
bars = 16
autosens = 1

[smoothing]
monstercat = 1
# waves = 1
waveform = 1
# noise_reduction = 1.5
gravity = 80

[output]
method = raw
raw_target = /dev/stdout
bit_format = 8bit
channels = mono

[eq]
1 = 1 # bass
2 = 1
3 = 1 # midtone
4 = 1
5 = 1 # treble


